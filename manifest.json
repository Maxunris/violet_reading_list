{
  "manifest_version": 3,
  "name": "Violet Reading List",
  "description": "Save pages to a reading list with folders, tags, favorites, pins, and cross-browser friendly organization.",
  "version": "0.1.0",
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "scripts/background.js",
    "type": "module",
    "scripts": [
      "scripts/background-firefox.js"
    ]
  },
  "action": {
    "default_title": "Violet Reading List",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "scripts/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "violet-reading-list@maxunris.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
